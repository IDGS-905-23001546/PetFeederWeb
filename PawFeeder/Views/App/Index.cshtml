@{
    ViewData["Title"] = "App - Inicio";
    ViewData["AppTitle"] = "Inicio";
    Layout = "_AppLayout";
}

<div class="px-4 py-3">

    <!-- Saludo -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-muted small mb-0">Buenos días 🌤️</p>
            <h5 class="fw-bold mb-0">Carlos</h5>
        </div>
        <div class="rounded-circle d-flex align-items-center justify-content-center"
             style="width:2.5rem;height:2.5rem;background:var(--pf-primary-light);">
            <i class="bi bi-bell" style="color:var(--pf-primary);"></i>
        </div>
    </div>

    <!-- Estado del dispositivo -->
    <div class="rounded-3 p-3 mb-4 text-white"
         style="background:linear-gradient(135deg,#16a34a,#22c55e);">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <p class="small opacity-75 mb-0">Dispositivo</p>
                <h6 class="fw-bold mb-0">PawFeeder #001</h6>
            </div>
            <span class="badge rounded-pill" style="background:rgba(255,255,255,0.25);">
                <i class="bi bi-circle-fill me-1" style="font-size:.5rem;"></i>En línea
            </span>
        </div>
        <div class="row g-2 text-center">
            <div class="col-4">
                <div class="rounded-2 py-2" style="background:rgba(255,255,255,0.2);">
                    <div class="fw-bold">72%</div>
                    <div class="small opacity-75">Croqueta</div>
                </div>
            </div>
            <div class="col-4">
                <div class="rounded-2 py-2" style="background:rgba(255,255,255,0.2);">
                    <div class="fw-bold">08:00</div>
                    <div class="small opacity-75">Próxima</div>
                </div>
            </div>
            <div class="col-4">
                <div class="rounded-2 py-2" style="background:rgba(255,255,255,0.2);">
                    <div class="fw-bold">3</div>
                    <div class="small opacity-75">Hoy</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Botón dispensar -->
    <button class="btn-pf w-100 py-3 mb-4 rounded-3" style="font-size:1rem;">
        <i class="bi bi-play-circle-fill me-2"></i>Dispensar ahora
    </button>

    <!-- Mascota activa -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">Mi mascota</h6>
        <a asp-controller="App" asp-action="Pets" class="small text-decoration-none" style="color:var(--pf-primary);">Ver todas</a>
    </div>

    <div class="pf-card d-flex align-items-center gap-3 mb-4">
        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:3.5rem;height:3.5rem;background:var(--pf-primary-light);font-size:1.6rem;">
            🐕
        </div>
        <div class="flex-grow-1">
            <h6 class="fw-bold mb-0">Buddy</h6>
            <p class="text-muted small mb-0">Golden Retriever · 12 kg</p>
        </div>
        <span class="pf-badge">80g / comida</span>
    </div>

    <!-- Próximos horarios -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">Horarios de hoy</h6>
        <a asp-controller="App" asp-action="Schedules" class="small text-decoration-none" style="color:var(--pf-primary);">Gestionar</a>
    </div>

    <div class="d-flex flex-column gap-2">
        @foreach (var (hora, estado, icon) in new[] {
            ("08:00 AM", "Completado", "check-circle-fill"),
            ("01:00 PM", "Próximo", "clock"),
            ("07:00 PM", "Pendiente", "clock")
        })
        {
            <div class="pf-card d-flex align-items-center gap-3 py-2">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:2.25rem;height:2.25rem;background:@(estado == "Completado" ? "var(--pf-primary-light)" : "var(--pf-border)");">
                    <i class="bi bi-@icon small" style="color:@(estado == "Completado" ? "var(--pf-primary)" : "var(--pf-muted)");"></i>
                </div>
                <div class="flex-grow-1">
                    <span class="fw-semibold small">@hora</span>
                    <span class="text-muted small ms-2">· 80g</span>
                </div>
                <span class="small @(estado == "Completado" ? "text-success" : "text-muted")">@estado</span>
            </div>
        }
    </div>

</div>
